model PhonicsProfile {
  id                           String   @id @default(cuid())
  studentId                    String   @unique @map("student_id")
  currentLessonId              String?  @map("current_lesson_id")
  placementMismatchSuspected   Boolean  @default(false) @map("placement_mismatch_suspected")
  placementUnderMatchSuspected Boolean  @default(false) @map("placement_under_match_suspected")
  comprehensionGapSuspected    Boolean  @default(false) @map("comprehension_gap_suspected")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")
  student                      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentLesson                Lesson?  @relation(fields: [currentLessonId], references: [id])

  @@map("phonics_profiles")
}

model StudentMastery {
  id                   String   @id @default(cuid())
  studentId            String   @map("student_id")
  lessonId             String   @map("lesson_id")
  status               String   @default("in_progress")
  attempts             Int      @default(0)
  lastDecodingAccuracy Float?   @map("last_decoding_accuracy")
  lastEncodingAccuracy Float?   @map("last_encoding_accuracy")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([studentId, lessonId])
  @@map("student_mastery")
}

model SpacedReviewItem {
  id                   String   @id @default(cuid())
  studentId            String   @map("student_id")
  itemId               String   @map("item_id")
  itemType             String   @map("item_type")
  currentIntervalIndex Int      @default(0) @map("current_interval_index")
  nextReviewDate       DateTime @map("next_review_date")
  consecutiveFailures  Int      @default(0) @map("consecutive_failures")
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([studentId, itemId, itemType])
  @@map("spaced_review_items")
}

