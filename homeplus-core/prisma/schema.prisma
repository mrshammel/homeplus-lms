generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User {
  id                String                   @id @default(cuid())
  name              String
  email             String                   @unique
  googleId          String?                  @unique @map("google_id")
  role              Role                     @default(STUDENT)
  gradeLevel        Int?                     @map("grade_level")
  avatar            String?
  enrolledAt        DateTime?                @map("enrolled_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  assignedTeacherId String?                  @map("assigned_teacher_id")
  onboardingStatus  OnboardingStatus         @default(NOT_STARTED) @map("onboarding_status")
  onboardingStep    Int                      @default(1) @map("onboarding_step")
  studentAgeBand    String?                  @map("student_age_band")
  requiresDecodableText Boolean              @default(false) @map("requires_decodable_text")
  readingSessions     ReadingSession[]
  assignedTeacher   User?                    @relation("TeacherStudents", fields: [assignedTeacherId], references: [id])
  students          User[]                   @relation("TeacherStudents")
  voiceProfile      VoiceProfile?
  subjectEnrollments SubjectEnrollment[]
  phonicsGaps       PhonicsGap[]
  phonicsProfile    PhonicsProfile?
  dashboardSummary  StudentDashboardSummary?
  progress          StudentProgress[]
  skillMastery      StudentSkillMastery[]
  unitAccess        StudentUnitAccess[]

  @@map("users")
}

model Subject {
  id                 String               @id @default(cuid())
  gradeLevel         Int                  @map("grade_level")
  name               String
  icon               String               @default("book")
  order              Int                  @default(0)
  active             Boolean              @default(false)
  units              Unit[]
  subjectEnrollments SubjectEnrollment[]

  @@map("subjects")
}

model SubjectEnrollment {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  subjectId  String   @map("subject_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  enrolledBy String?  @map("enrolled_by")
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@map("subject_enrollments")
}

model Unit {
  id            String              @id @default(cuid())
  subjectId     String              @map("subject_id")
  title         String
  description   String?
  icon          String?
  order         Int                 @default(0)
  lessons       Lesson[]
  pacingTargets PacingTarget?
  subject       Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studentAccess StudentUnitAccess[]
  unitMasterySummaries UnitMasterySummary[]

  @@index([subjectId])
  @@map("units")
}

model Lesson {
  id                  String                  @id @default(cuid())
  unitId              String                  @map("unit_id")
  title               String
  description         String?
  order               Int                     @default(0)
  content             Json
  contentStatus       String                  @default("DRAFT") @map("content_status")
  duration            Int?
  unit                Unit                    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress            LessonProgress[]
  pacingTargets       PacingTarget[]
  studentSkillMastery StudentSkillMastery[]
  masteryEvidence     MasteryEvidence[]
  reflectionEntries   ReflectionEntry[]
  phonicsProfiles     PhonicsProfile[]

  @@index([unitId])
  @@map("lessons")
}

model LessonSectionProgress {
  id               String        @id @default(cuid())
  lessonProgressId String        @map("lesson_progress_id")
  section          LessonSection
  status           ProgressStatus @default(NOT_STARTED)
  completedAt      DateTime?     @map("completed_at")
  lessonProgress   LessonProgress @relation(fields: [lessonProgressId], references: [id], onDelete: Cascade)

  @@unique([lessonProgressId, section])
  @@map("lesson_section_progress")
}

model LessonProgress {
  id              String                  @id @default(cuid())
  studentId       String                  @map("student_id")
  lessonId        String                  @map("lesson_id")
  status          ProgressStatus          @default(NOT_STARTED)
  lastAccessed    DateTime                @default(now()) @map("last_accessed")
  completedAt     DateTime?               @map("completed_at")
  currentSection  LessonSection           @default(WARM_UP) @map("current_section")
  lesson          Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student         User                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionProgress LessonSectionProgress[]

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}

model PacingTarget {
  id              String   @id @default(cuid())
  unitId          String   @unique @map("unit_id")
  lessonId        String?  @map("lesson_id")
  targetDate      DateTime @map("target_date")
  lessonsPerWeek  Float    @map("lessons_per_week")
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  suggestedLesson Lesson?  @relation(fields: [lessonId], references: [id])

  @@map("pacing_targets")
}

model StudentUnitAccess {
  id            String            @id @default(cuid())
  studentId     String            @map("student_id")
  unitId        String            @map("unit_id")
  overrideState UnitOverrideState @default(NONE) @map("override_state")
  unlockedAt    DateTime?         @map("unlocked_at")
  student       User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unit          Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([studentId, unitId])
  @@map("student_unit_access")
}

model Skill {
  id                  String                @id @default(cuid())
  name                String
  description         String?
  category            String?
  level               Int                   @default(1)
  order               Int                   @default(0)
  studentSkillMastery StudentSkillMastery[]
  masteryEvidence     MasteryEvidence[]

  @@map("skills")
}

model StudentSkillMastery {
  id          String        @id @default(cuid())
  studentId   String        @map("student_id")
  skillId     String        @map("skill_id")
  lessonId    String?       @map("lesson_id")
  status      MasteryStatus @default(NOT_STARTED)
  lastTested  DateTime?     @map("last_tested")
  masteredAt  DateTime?     @map("mastered_at")
  student     User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill       Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lesson      Lesson?       @relation(fields: [lessonId], references: [id])

  @@unique([studentId, skillId])
  @@index([studentId])
  @@map("student_skill_mastery")
}

model MasteryEvidence {
  id              String   @id @default(cuid())
  studentId       String   @map("student_id")
  skillId         String   @map("skill_id")
  lessonId        String   @map("lesson_id")
  score           Float
  notes           String?
  capturedAt      DateTime @default(now()) @map("captured_at")
  skill           Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([studentId, skillId])
  @@map("mastery_evidence")
}

model ReflectionEntry {
  id          String   @id @default(cuid())
  studentId   String   @map("student_id")
  lessonId    String   @map("lesson_id")
  content     String
  mood        String?
  submittedAt DateTime @default(now()) @map("submitted_at")
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([studentId, lessonId])
  @@map("reflection_entries")
}

model ReadingSession {
  id          String    @id @default(cuid())
  studentId   String    @map("student_id")
  bookId      String?   @map("book_id")
  duration    Int
  pagesRead   Int?      @map("pages_read")
  summary     String?
  completedAt DateTime  @default(now()) @map("completed_at")
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("reading_sessions")
}

model VoiceProfile {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  sampleUrl  String   @map("sample_url")
  settings   Json?
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_profiles")
}

model PhonicsGap {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  skillId    String?  @map("skill_id")
  notes      String?
  detectedAt DateTime @default(now()) @map("detected_at")
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("phonics_gaps")
}

model PhonicsProfile {
  id                            String   @id @default(cuid())
  studentId                     String   @unique @map("student_id")
  currentLessonId               String?  @map("current_lesson_id")
  placementMismatchSuspected    Boolean  @default(false) @map("placement_mismatch_suspected")
  placementUnderMatchSuspected  Boolean  @default(false) @map("placement_under_match_suspected")
  comprehensionGapSuspected      Boolean  @default(false) @map("comprehension_gap_suspected")
  student                       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentLesson                 Lesson?  @relation(fields: [currentLessonId], references: [id])

  @@map("phonics_profiles")
}

model StudentDashboardSummary {
  id            String   @id @default(cuid())
  studentId     String   @unique @map("student_id")
  totalLessons  Int      @default(0) @map("total_lessons")
  completedLessons Int   @default(0) @map("completed_lessons")
  masteredSkills Int     @default(0) @map("mastered_skills")
  lastActivity  DateTime? @map("last_activity")
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_dashboard_summaries")
}

model StudentProgress {
  id              String   @id @default(cuid())
  studentId       String   @map("student_id")
  courseId        String?  @map("course_id")
  percentComplete Float    @default(0) @map("percent_complete")
  updatedAt       DateTime @updatedAt @map("updated_at")
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@map("student_progress")
}

model UnitMasterySummary {
  id             String   @id @default(cuid())
  studentId      String   @map("student_id")
  unitId         String   @map("unit_id")
  masteredSkills Int      @default(0) @map("mastered_skills")
  totalSkills    Int      @default(0) @map("total_skills")
  updatedAt      DateTime @updatedAt @map("updated_at")
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([studentId, unitId])
  @@map("unit_mastery_summaries")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LessonSection {
  WARM_UP
  INSTRUCTION
  PRACTICE
  ASSESSMENT
  REFLECTION
}

enum UnitOverrideState {
  NONE
  LOCKED
  UNLOCKED
}

enum MasteryStatus {
  NOT_STARTED
  INTRODUCED
  PRACTICING
  MASTERED
}
